ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
# ALPACA_MODE=paper   # paper | live  (overrides config.yaml)

# --- Notifications (all optional — configure only the channels you want) ---

# Email (Gmail): create an App Password at myaccount.google.com/apppasswords
# NOTIFY_EMAIL_TO=you@gmail.com
# NOTIFY_EMAIL_FROM=sender@gmail.com
# NOTIFY_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# SMS (Twilio): sign up at twilio.com — free trial gives ~$15 credit
# NOTIFY_TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTIFY_TWILIO_TOKEN=your_auth_token
# NOTIFY_TWILIO_FROM=+15005550006
# NOTIFY_TWILIO_TO=+1xxxxxxxxxx

# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# NOTIFY_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
