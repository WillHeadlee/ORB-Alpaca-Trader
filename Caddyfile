:80 {
    # API — proxy to FastAPI, no caching
    @api path /api/*
    handle @api {
        reverse_proxy localhost:8000
        header Cache-Control "no-store"
    }

    # Everything else — serve React SPA
    handle {
        root * /opt/orb-trader/frontend/dist
        file_server
        try_files {path} /index.html
    }

    log {
        output file /var/log/caddy/orb-trader.log
    }
}

# Uncomment and replace with your domain for auto-HTTPS:
# yourdomain.com {
#     reverse_proxy /api/* localhost:8000
#     root * /opt/orb-trader/frontend/dist
#     file_server
#     try_files {path} /index.html
# }
