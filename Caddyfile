:80 {
    # API endpoints
    reverse_proxy /api/* localhost:8000

    # Serve static frontend files
    root * /opt/orb-trader/frontend/dist
    file_server
    try_files {path} /index.html

    log {
        output file /var/log/caddy/orb-trader.log
    }
}

